+func (h *Handler) removeAuthFilesByStatus(c *gin.Context, status string, removedSubDir string) {
+	if h.authManager == nil {
+		c.JSON(http.StatusServiceUnavailable, gin.H{"error": "core auth manager unavailable"})
+		return
+	}
+	if h.cfg == nil {
+		c.JSON(http.StatusInternalServerError, gin.H{"error": "config unavailable"})
+		return
+	}
+
+	resolvedAuthDir, errResolveAuthDir := util.ResolveAuthDir(h.cfg.AuthDir)
+	if errResolveAuthDir != nil {
+		c.JSON(http.StatusInternalServerError, gin.H{"error": fmt.Sprintf("failed to resolve auth dir: %v", errResolveAuthDir)})
+		return
+	}
+	targetDir := filepath.Join(resolvedAuthDir, "removed", removedSubDir)
+
+	loc, errLocation := time.LoadLocation("Asia/Shanghai")
+	if errLocation != nil {
+		loc = time.FixedZone("Asia/Shanghai", 8*60*60)
+	}
+	timestamp := time.Now().In(loc).Format("20060102-150405")
+	if errMkdir := os.MkdirAll(targetDir, 0o700); errMkdir != nil {
+		c.JSON(http.StatusInternalServerError, gin.H{"error": fmt.Sprintf("failed to create target dir: %v", errMkdir)})
+		return
+	}
+
+	ctx := c.Request.Context()
+	removedFiles := make([]string, 0)
+	movedPaths := make(map[string]struct{})
+
+	for _, auth := range h.authManager.List() {
+		if auth == nil || string(auth.Status) != status {
+			continue
+		}
+		sourcePath := h.sourcePathForInvalidAuth(auth)
+		if sourcePath == "" {
+			c.JSON(http.StatusInternalServerError, gin.H{"error": "auth file path is empty"})
+			return
+		}
+		sourcePath = cleanAuthFilePath(sourcePath)
+		if _, seen := movedPaths[sourcePath]; seen {
+			continue
+		}
+		movedPaths[sourcePath] = struct{}{}
+
+		removedName := filepath.Base(sourcePath) + ".removed-" + timestamp
+		targetPath := filepath.Join(targetDir, removedName)
+		if errMove := moveAuthFile(sourcePath, targetPath); errMove != nil {
+			c.JSON(http.StatusInternalServerError, gin.H{"error": fmt.Sprintf("failed to move file: %v", errMove)})
+			return
+		}
+		h.removeAuthsForPath(ctx, sourcePath, strings.TrimSpace(auth.ID))
+		removedFiles = append(removedFiles, removedName)
+	}
+
+	if errLoad := h.authManager.Load(ctx); errLoad != nil {
+		c.JSON(http.StatusInternalServerError, gin.H{"error": fmt.Sprintf("failed to reload auth pool: %v", errLoad)})
+		return
+	}
+
+	c.JSON(http.StatusOK, gin.H{
+		"removed":    len(removedFiles),
+		"target_dir": targetDir,
+		"files":      removedFiles,
+	})
+}
+
+func (h *Handler) sourcePathForInvalidAuth(auth *coreauth.Auth) string {
