+func responsesWebsocketErrorStatus(errMsg *interfaces.ErrorMessage) int {
+	if errMsg == nil {
+		return 0
+	}
+	status := errMsg.StatusCode
+	if status <= 0 && errMsg.Error != nil {
+		if se, ok := errMsg.Error.(interface{ StatusCode() int }); ok && se != nil {
+			status = se.StatusCode()
+		}
+	}
+	return status
+}
+
+func responsesWebsocketPinnedAuthQuotaCooling(manager *coreauth.Manager, authID string, model string, now time.Time) bool {
+	if manager == nil {
+		return false
+	}
+	authID = strings.TrimSpace(authID)
+	if authID == "" {
+		return false
+	}
+	auth, ok := manager.GetByID(authID)
+	if !ok || auth == nil {
+		return false
+	}
+	if responsesWebsocketQuotaCooling(auth.Quota, now) {
+		return true
+	}
+	model = strings.TrimSpace(model)
+	if model == "" || auth.ModelStates == nil {
+		return false
+	}
+	if state := auth.ModelStates[model]; state != nil && responsesWebsocketQuotaCooling(state.Quota, now) {
+		return true
+	}
+	return false
+}
+
+func responsesWebsocketQuotaCooling(quota coreauth.QuotaState, now time.Time) bool {
+	return quota.Exceeded && !quota.NextRecoverAt.IsZero() && quota.NextRecoverAt.After(now)
+}
