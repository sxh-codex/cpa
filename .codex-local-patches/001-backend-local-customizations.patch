+	if name == "" || h == nil || h.cfg == nil {
+		return ""
+	}
+	resolvedAuthDir, errResolve := util.ResolveAuthDir(h.cfg.AuthDir)
+	if errResolve != nil {
+		return ""
+	}
+	return filepath.Join(resolvedAuthDir, filepath.Base(name))
+}
