+func TestRecordOpenAIQuotaSampleFromAPICallRequiresExactCodexUsageURL(t *testing.T) {
+	t.Parallel()
+
+	auth := &coreauth.Auth{
+		ID:       "codex-oauth",
+		Provider: "codex",
+		FileName: "codex-user.json",
