+func moveAuthFile(sourcePath string, targetPath string) error {
+	if strings.TrimSpace(sourcePath) == "" || strings.TrimSpace(targetPath) == "" {
+		return fmt.Errorf("source and target paths are required")
+	}
+	if errRename := os.Rename(sourcePath, targetPath); errRename == nil {
+		return nil
+	}
+
+	input, errOpen := os.Open(sourcePath)
+	if errOpen != nil {
+		return errOpen
+	}
+	defer func() {
+		if errClose := input.Close(); errClose != nil {
+			log.Errorf("source auth file close error: %v", errClose)
+		}
+	}()
+
+	output, errCreate := os.OpenFile(targetPath, os.O_WRONLY|os.O_CREATE|os.O_TRUNC, 0o600)
+	if errCreate != nil {
+		return errCreate
+	}
+	copyOK := false
+	defer func() {
+		if errClose := output.Close(); errClose != nil {
+			log.Errorf("target auth file close error: %v", errClose)
+		}
+		if !copyOK {
+			if errRemove := os.Remove(targetPath); errRemove != nil && !os.IsNotExist(errRemove) {
+				log.Errorf("failed to remove partial auth file: %v", errRemove)
+			}
+		}
+	}()
+
+	if _, errCopy := io.Copy(output, input); errCopy != nil {
+		return errCopy
+	}
+	copyOK = true
+	if errRemove := os.Remove(sourcePath); errRemove != nil {
+		return errRemove
+	}
+	return nil
+}
